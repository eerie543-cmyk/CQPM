# ── CQPM remote control (cqpm-control on Vercel) ─────────────────────
# Copy this file to `.env` and fill in the real values.
# Leave them blank and the app runs fully offline ("Local" mode) — no lock,
# no announcements, no update checks, but everything else works normally.

# Full URL of the config endpoint, e.g. https://cqpm-control.vercel.app/api/config
VITE_REMOTE_CONFIG_URL=

# The APP secret (matches CQPM_APP_SECRET set in the cqpm-control Vercel project).
# This is read-only access — it can fetch config and post heartbeats, nothing else.
VITE_REMOTE_SECRET=

# The version this build reports to the backend. Bump it on every release so the
# "update available" banner clears itself once users are on the new version.
VITE_APP_VERSION=1.0.0
