{
  "name": "cqpm",
  "version": "1.0.1",
  "description": "Continuous Quality Process Monitoring",
  "author": "Aadvik",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.aadvik.cqpm",
    "productName": "CQPM",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "icon": "favicon.ico",
    "extraResources": [
      {
        "from": ".env.beta",
        "to": ".env"
      },
      {
        "from": "favicon.ico",
        "to": "favicon.ico"
      }
    ],
    "asar": true,
    "win": {
      "icon": "favicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "CQPM-Beta-Setup-${version}.${ext}",
      "installerIcon": "favicon.ico",
      "uninstallerIcon": "favicon.ico"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.41.0",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "electron": "^32.0.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^0.454.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
